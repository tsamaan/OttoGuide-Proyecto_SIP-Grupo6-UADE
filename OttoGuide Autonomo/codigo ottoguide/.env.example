# ════════════════════════════════════════════════════════════
# OttoGuide — Variables de entorno
# ════════════════════════════════════════════════════════════
# Copiar este archivo como .env y ajustar valores segun el entorno.
#   cp .env.example .env

# --- Modo de operacion ---
ROBOT_MODE=mock
# real → robot fisico (requiere ROBOT_NETWORK_INTERFACE)
# sim  → simulador MuJoCo (requiere unitree_mujoco en domain 1)
# mock → stub en memoria (CI/CD, sin procesos externos)

# --- Interfaz de red para DDS (solo si ROBOT_MODE=real) ---
ROBOT_NETWORK_INTERFACE=eth0
# Requerida solo si ROBOT_MODE=real

# --- NLP / LLM (Ollama local) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# ════════════════════════════════════════════════════════════
# Configuracion DDS para modo real (en entorno de sistema, no aqui):
# CYCLONEDDS_URI=<CycloneDDS><Domain><General>
#   <NetworkInterfaceAddress>eth0</NetworkInterfaceAddress>
#   </General><Discovery><Peers>
#   <Peer address="192.168.123.161"/>
#   </Peers></Discovery></Domain></CycloneDDS>
# Para modo sim, CycloneDDS usa loopback automaticamente con domain 1.
